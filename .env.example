# Neo4j (from console.neo4j.io Aura free tier)
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# Butterbase (from dashboard.butterbase.ai -> app settings -> API keys)
BUTTERBASE_APP_ID=app_xxxxxxxx
BUTTERBASE_API_KEY=changeme
BUTTERBASE_PRO_PLAN_ID=changeme

# RocketRide Cloud (from cloud.rocketride.ai account -> API key)
ROCKETRIDE_URI=https://api.rocketride.ai
ROCKETRIDE_APIKEY=changeme
# Cached task token from the first POST /task call (RocketRide errors on
# re-creating an already-running pipeline) — leave blank on first run.
ROCKETRIDE_TASK_TOKEN=

# Anthropic (used directly for skill extraction; see server/rocketride.js)
ANTHROPIC_API_KEY=changeme

PORT=3000
