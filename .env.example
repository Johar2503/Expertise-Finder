# Neo4j (from console.neo4j.io Aura free tier)
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme

# Butterbase (from dashboard.butterbase.ai -> project settings -> API keys)
BUTTERBASE_PROJECT_URL=https://api.butterbase.ai/v1/<your-project-id>
BUTTERBASE_API_KEY=changeme
BUTTERBASE_PRO_PRICE_ID=changeme

# RocketRide Cloud (from cloud.rocketride.ai -> deployed pipeline -> endpoint)
ROCKETRIDE_PIPELINE_URL=https://cloud.rocketride.ai/api/pipelines/<pipeline-id>/run
ROCKETRIDE_API_KEY=changeme

PORT=3000
